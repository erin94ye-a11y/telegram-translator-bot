TELEGRAM_BOT_TOKEN=replace_with_your_telegram_bot_token
OPENAI_API_KEY=replace_with_your_openai_api_key

# Default model requested for this bot.
OPENAI_MODEL=gpt-5.4-mini

# OpenAI translation jobs processed at the same time.
TRANSLATION_CONCURRENCY=10

# 0 means unlimited queue. Messages above the 10 active jobs wait silently.
QUEUE_MAXSIZE=0

# true clears Telegram updates that arrived while the bot was offline.
DROP_PENDING_UPDATES=false

# INFO is usually enough for production.
LOG_LEVEL=INFO
